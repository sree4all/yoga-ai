# Server-side only — never expose to the browser bundle
# Copy to .env.local for local development

# Abort orchestration after this many milliseconds (default 30000 per FR-010).
# Raise if OpenAI returns 429 with long Retry-After (retries wait inside this window).
ROUTINE_GEN_TIMEOUT_MS=30000

# =============================================================================
# GenOrchestrator (https://github.com/sree4all/genorchestrator)
# Self-hosted FastAPI app; OpenAI-compatible API at POST /v1/chat/completions
# Docs: https://github.com/sree4all/genorchestrator/blob/main/docs/api.md
# Server env (Postgres, Redis, provider keys) lives on the orchestrator — see its env.example
# =============================================================================

# Base URL of your running GenOrchestrator instance (no trailing slash)
GENORCHESTRATOR_BASE_URL=http://localhost:8000

# API key issued by GenOrchestrator (e.g. after: python scripts/create_user.py user@example.com)
# Authorization: Bearer <this key> — NOT the OpenAI/Anthropic keys (those go in GenOrchestrator's .env)
GENORCHESTRATOR_API_KEY=

# Model name routed by GenOrchestrator (must exist for configured providers)
GENORCHESTRATOR_MODEL=gpt-3.5-turbo

# Optional: auto | cost_optimized | openai | anthropic | google | round_robin
# https://github.com/sree4all/genorchestrator/blob/main/docs/api.md
GENORCHESTRATOR_PROVIDER_PREFERENCE=

# Set to "false" if your upstream does not support OpenAI-style response_format json_object
GENORCHESTRATOR_USE_JSON_OBJECT=true

# =============================================================================
# Direct OpenAI (wins over GenOrchestrator when OPENAI_API_KEY is set)
# =============================================================================
OPENAI_API_KEY=
# Default in code: gpt-4o-mini (cheap; good for JSON routines). Override if your org allows other IDs.
# If logs show insufficient_quota, fix billing/credits on platform.openai.com — not "wrong model".
OPENAI_MODEL=gpt-4o-mini

# Cap completion size for cost control (default 2048; enough for routine JSON)
OPENAI_MAX_TOKENS=2048

# Retries after HTTP 429 (rate limit); uses Retry-After when present (default 3, max 8).
# Retries are skipped automatically for insufficient_quota (billing).
OPENAI_MAX_ATTEMPTS=3

# When OPENAI_API_KEY is unset and GenOrchestrator (base + key) is incomplete, the app uses a
# deterministic mock from the static knowledge module.
