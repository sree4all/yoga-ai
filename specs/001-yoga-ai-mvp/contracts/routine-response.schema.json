{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yoga-ai.local/contracts/routine-response.schema.json",
  "title": "RoutineResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "disclaimer"],
  "properties": {
    "kind": { "type": "string", "enum": ["safe_routine", "restricted", "generation_fallback"] },
    "disclaimer": {
      "type": "string",
      "description": "Non-medical positioning copy; not a substitute for professional advice."
    },
    "routine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "totalDurationMinutes", "steps"],
      "properties": {
        "title": { "type": "string" },
        "totalDurationMinutes": { "type": "number", "minimum": 1, "maximum": 30 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["poseId", "instruction"],
            "properties": {
              "poseId": { "type": "string" },
              "instruction": { "type": "string" },
              "durationSeconds": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "restricted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["breathingSteps"],
      "properties": {
        "breathingSteps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["instruction"],
            "properties": {
              "instruction": { "type": "string" },
              "durationSeconds": { "type": "number", "minimum": 0 }
            }
          }
        },
        "careGuidance": { "type": "string" }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message", "breathingSteps", "retryAvailable"],
      "properties": {
        "message": { "type": "string" },
        "breathingSteps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["instruction"],
            "properties": {
              "instruction": { "type": "string" },
              "durationSeconds": { "type": "number", "minimum": 0 }
            }
          }
        },
        "retryAvailable": { "type": "boolean", "const": true }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "safe_routine" } } },
      "then": { "required": ["routine"] }
    },
    {
      "if": { "properties": { "kind": { "const": "restricted" } } },
      "then": { "required": ["restricted"] }
    },
    {
      "if": { "properties": { "kind": { "const": "generation_fallback" } } },
      "then": { "required": ["fallback"] }
    }
  ]
}
