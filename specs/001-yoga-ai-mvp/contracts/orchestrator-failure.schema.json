{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yoga-ai.local/contracts/orchestrator-failure.schema.json",
  "title": "OrchestratorFailureEnvelope",
  "description": "Optional HTTP layer: 503 or 200 with kind=generation_fallback; implementers choose one pattern consistently.",
  "type": "object",
  "additionalProperties": false,
  "required": ["error", "fallback"],
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "enum": ["TIMEOUT", "ORCHESTRATOR_ERROR", "VALIDATION_ERROR"] },
        "message": { "type": "string" }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message", "breathingSteps", "retryAvailable"],
      "properties": {
        "message": { "type": "string" },
        "breathingSteps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["instruction"],
            "properties": {
              "instruction": { "type": "string" },
              "durationSeconds": { "type": "number", "minimum": 0 }
            }
          }
        },
        "retryAvailable": { "type": "boolean", "const": true }
      }
    }
  }
}
